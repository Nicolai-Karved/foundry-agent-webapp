{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Identity": "Debug",
      "WebApp.Api.Services": "Debug"
    }
  },
  "AI_AGENT_ENDPOINT": "PLACEHOLDER_SET_VIA_ENV_VAR_OR_AZD_PREPROVISION",
  "AI_AGENT_ID": "PLACEHOLDER_SET_VIA_ENV_VAR_OR_AZD_PREPROVISION",
  "AI_SEARCH_ENDPOINT": "PLACEHOLDER_SET_VIA_ENV_VAR_OR_AZD_PREPROVISION",
  "AI_SEARCH_INDEX": "bim-standards-paragraph-index",
  "AI_SEARCH_KEY": "PLACEHOLDER_SET_VIA_ENV_VAR_OR_AZD_PREPROVISION",
  "StandardsPolicy": {
    "DocType": "AIR",
    "ValidationMode": "strict",
    "ScoringMethod": "weighted_by_priority",
    "MandatoryWeight": 1.0,
    "NonMandatoryWeight": 0.5,
    "CriticalFailsImmediate": true,
    "MaxMajorBeforeFail": 0,
    "ScoringNotes": "Mandatory standards weighted highest."
  },
  "StandardsRetrieval": {
    "TopKClausesPerStandard": 6,
    "ChunkType": "paragraph",
    "SemanticConfiguration": "bim-standards-semantic-config"
  },
  "StandardsCompliance": {
    "RequirementsFirstEnabled": true,
    "RequirementsFirstMaxPerStandard": 500,
    "RequirementsFirstPageSize": 100
  },
  "EvaluationTaskSync": {
    "Enabled": false,
    "SchemaVersion": "fs-0002/v1",
    "Payload": {
      "MaxRequestBodyBytes": 1048576,
      "MaxTasksPerPayload": 250,
      "MaxDescriptionLength": 4000,
      "MaxCitationLength": 4000,
      "MaxAnchorExcerptLength": 2000,
      "MaxResolutionNoteLength": 2000
    },
    "Persistence": {
      "Provider": "PostgreSql",
      "PreferredConnectionStringName": "Fs0002TaskPersistence",
      "PreferredSchema": "fs0002",
      "AutoMigrateOnStartup": false,
      "ReuseGatewayDatabaseCandidate": true,
      "RequireDedicatedSchema": true,
      "RequireDedicatedRoles": true
    }
  },
  "CORS": {
    "AllowedOrigins": [
      "http://localhost:8089",
      "http://localhost:5173"
    ]
  }
}
